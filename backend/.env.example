# All variables are prefixed KIRANA_ (parsed by pydantic-settings)

# ── Server ────────────────────────────────────────────────────────────────────
KIRANA_APP_NAME=KiranaOS
KIRANA_LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, no setup required):
KIRANA_DATABASE_URL=sqlite:///./data/kiranaos.db
# PostgreSQL (production):
# KIRANA_DATABASE_URL=postgresql://user:password@host:5432/kiranaos

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# Choose either Twilio or Meta Cloud API as your inbound provider.
# The webhook route maps provider-specific payloads to the normalised ingestion API.

# Verification token — set to any secret string, paste the same value in your
# provider's webhook dashboard.
KIRANA_WHATSAPP_VERIFY_TOKEN=change-me-before-deploy
KIRANA_PUBLIC_BASE_URL=http://localhost:8000

# Twilio (if using Twilio for WhatsApp)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# KIRANA_TWILIO_AUTH_TOKEN=your_auth_token

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production, set this to your frontend's actual origin
KIRANA_FRONTEND_ORIGIN=http://localhost:5173

# ── Google Cloud Vision (OCR for handwritten order photos) ───────────────────
# Option A: path to a service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Option B: paste the JSON content directly (for Railway, Render, Fly.io)
# KIRANA_GOOGLE_VISION_KEY_JSON={"type":"service_account","project_id":"..."}

# ── OpenAI (optional — improves multilingual NLP accuracy) ───────────────────
# KIRANA_OPENAI_API_KEY=sk-...

# ── Demo mode ─────────────────────────────────────────────────────────────────
KIRANA_DEMO_MODE=true
